# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
LLM_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=1

# Latency budgets
ANALYZE_MAX_SECONDS=28
HEALTH_MAX_SECONDS=60

# Evidence thresholds
AMOUNT_TOLERANCE_PCT=0.02
DATE_WINDOW_DAYS=3
HIGH_VALUE_THRESHOLD_TAKA=10000
CRITICAL_VALUE_THRESHOLD_TAKA=50000
TIE_SCORE_DELTA=0.05
MIN_CONFIDENCE_THRESHOLD=0.6

# Server
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=*